{
  "name": "originpass",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "contracts:build": "forge build",
    "contracts:test": "forge test -vv",
    "contracts:abis": "forge inspect RegistroEmpresas abi > artifacts/RegistroEmpresas.abi.json && forge inspect PasaporteProductos abi > artifacts/PasaporteProductos.abi.json && forge inspect PasaporteOrigen abi > artifacts/PasaporteOrigen.abi.json",
    "deploy:testnet": "bash scripts/deploy-v2.sh",
    "vercel:envs": "bash scripts/vercel-envs.sh"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "qrcode": "^1.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "viem": "^2.52.2",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
