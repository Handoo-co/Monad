{
  "project": "Handoo OriginPass V2",
  "network": {
    "name": "Monad Testnet",
    "chainId": 10143,
    "chainIdHex": "0x279f",
    "nativeCurrency": {
      "name": "MON",
      "symbol": "MON",
      "decimals": 18
    },
    "rpcUrl": "https://testnet-rpc.monad.xyz",
    "explorers": {
      "socialscan": "https://monad-testnet.socialscan.io",
      "monadVision": "https://testnet.monadvision.com",
      "monadscan": "https://testnet.monadscan.com"
    }
  },
  "contracts": {
    "registroEmpresas": {
      "name": "RegistroEmpresas",
      "address": null,
      "abiPath": "artifacts/RegistroEmpresas.abi.json",
      "solidityPath": "contracts/RegistroEmpresas.sol",
      "env": "VITE_REGISTRO_EMPRESAS_ADDRESS"
    },
    "pasaporteProductos": {
      "name": "PasaporteProductos",
      "address": null,
      "abiPath": "artifacts/PasaporteProductos.abi.json",
      "solidityPath": "contracts/PasaporteProductos.sol",
      "env": "VITE_PASAPORTE_PRODUCTOS_ADDRESS"
    }
  },
  "functions": {
    "company": {
      "request": "solicitarRegistroEmpresa",
      "approve": "aprobarEmpresa",
      "reject": "rechazarEmpresa",
      "suspend": "suspenderEmpresa",
      "reactivate": "reactivarEmpresa",
      "getByAccount": "obtenerEmpresaPorCuenta"
    },
    "product": {
      "register": "registrarProducto",
      "verify": "verificarProducto",
      "getByHash": "obtenerProductoPorHash",
      "revoke": "revocarProducto"
    }
  },
  "qr": {
    "route": "/p/:chainId/:productContract/:productId?hash=:productHash",
    "claim": "Camara/registro verifica empresa; empresa o Handoo atesta origen del producto."
  }
}
